rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'rolandabellanosa321@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Validations helper for membership signups
    function isValidMembershipSignup(data) {
      return data.fullName is string && data.fullName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.phone is string && data.phone.size() <= 30 &&
             data.tierId is string && data.tierId.size() <= 50 &&
             data.ticketId is string && data.ticketId.size() <= 50 &&
             data.status is string && (data.status == 'pending' || data.status == 'claimed' || data.status == 'canceled');
    }

    // Validations helper for class reservations
    function isValidClassReservation(data) {
      return data.fullName is string && data.fullName.size() <= 100 &&
             data.phone is string && data.phone.size() <= 30 &&
             data.classId is string && data.classId.size() <= 50 &&
             data.className is string && data.className.size() <= 100 &&
             data.ticketId is string && data.ticketId.size() <= 50 &&
             data.status is string && (data.status == 'reserved' || data.status == 'checked-in' || data.status == 'canceled');
    }

    // Validations helper for messages
    function isValidContactMessage(data) {
      return data.message is string && data.message.size() <= 1000;
    }

    // Membership signups resource
    match /membership_signups/{signupId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Class reservations resource
    match /class_reservations/{reservationId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Contact feedback messages
    match /contact_messages/{messageId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
  }
}
